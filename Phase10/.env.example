# ==============================================================================
# DineWise AI - Phase 10 Vercel Deployment Environment Variables
# ==============================================================================
#
# Choose one of the routing strategies below and configure in the Vercel dashboard.

# ------------------------------------------------------------------------------
# Option 1: Rewrite Proxy (Recommended)
# Next.js will proxy requests at "/api/*" to this backend base.
# ------------------------------------------------------------------------------
BACKEND_API_BASE=https://your-phase8-render-service.onrender.com

# ------------------------------------------------------------------------------
# Option 2: Direct Client Calls
# The browser will send requests directly to this URL (requires CORS enabled on Render).
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE=https://your-phase8-render-service.onrender.com/api/v1
